{
  "collectionName": "components_homepage_hero_adjectives",
  "info": {
    "displayName": "Hero Adjective"
  },
  "options": {},
  "attributes": {
    "text": {
      "type": "string",
      "required": true
    },
    "color1": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "customField": "plugin::color-picker.color",
      "required": true
    },
    "color2": {
      "type": "customField",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$",
      "customField": "plugin::color-picker.color",
      "required": true
    },
    "effect": {
      "type": "enumeration",
      "enum": [
        "wave",
        "shake",
        "blurry"
      ],
      "default": "wave",
      "required": true
    }
  }
}
